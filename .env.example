# Resend — clé API pour l'envoi d'emails depuis le form contact.
# https://resend.com → Sign up → API Keys → Create API Key.
# Free tier : 100 emails/jour, suffisant pour démarrer.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx

# Email destinataire des leads du form contact.
CONTACT_TO_EMAIL=contact@groupe-merlin.fr

# Email d'expéditeur. Tant qu'aucun domaine n'est vérifié sur Resend,
# garde "onboarding@resend.dev" (Resend l'autorise par défaut).
# Une fois groupe-merlin.fr vérifié sur Resend, passer à "Groupe Merlin <contact@groupe-merlin.fr>".
CONTACT_FROM_EMAIL=Groupe Merlin <onboarding@resend.dev>
